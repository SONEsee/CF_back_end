{
  "info": {
    "name": "go-echo-template — Zone 3: Product Catalog",
    "description": "product_categories, products, product_images, product_variants (+auto-inventory), inventories, stock_movements, stock_reservations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "1. Product Categories",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/product-category/create",
            "body": { "mode": "raw", "raw": "{\n  \"shop_id\": 1,\n  \"name\": \"ເສື້ອຜ້າ\",\n  \"sort_order\": 1\n}" }
          }
        },
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/product-category/category?page=1&limit=10" } },
        {
          "name": "Update (PATCH)",
          "request": {
            "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/product-category/category/1/",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"ເສື້ອຜ້າ (ອັບເດດ)\"\n}" }
          }
        },
        { "name": "Delete", "request": { "method": "DELETE", "url": "{{base_url}}/product-category/category/1/" } }
      ]
    },
    {
      "name": "2. Products",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/product/create",
            "body": { "mode": "raw", "raw": "{\n  \"shop_id\": 1,\n  \"category_id\": 1,\n  \"product_name\": \"ເສື້ອຢືດຄໍມົນ\",\n  \"description\": \"ຜ້າຝ້າຍ 100%\"\n}" }
          }
        },
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/product/product?page=1&limit=10" } },
        {
          "name": "Update (PATCH)",
          "request": {
            "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/product/product/1/",
            "body": { "mode": "raw", "raw": "{\n  \"is_active\": true\n}" }
          }
        },
        { "name": "Delete (soft-delete ຈິງ)", "request": { "method": "DELETE", "url": "{{base_url}}/product/product/1/" } }
      ]
    },
    {
      "name": "3. Product Images",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/product-image/create",
            "body": { "mode": "raw", "raw": "{\n  \"product_id\": 1,\n  \"image_url\": \"https://example.com/img1.jpg\",\n  \"sort_order\": 1\n}" }
          }
        },
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/product-image/image?page=1&limit=10" } },
        { "name": "Delete", "request": { "method": "DELETE", "url": "{{base_url}}/product-image/image/1/" } }
      ]
    },
    {
      "name": "4. Product Variants",
      "item": [
        {
          "name": "Create (auto-creates inventory)",
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/product-variant/create",
            "body": { "mode": "raw", "raw": "{\n  \"product_id\": 1,\n  \"variant_name\": \"ໄຊສ໌ M ສີດຳ\",\n  \"sku_code\": \"TSHIRT-M-BLACK\",\n  \"price\": 89000,\n  \"cost_price\": 50000,\n  \"weight_grams\": 200\n}" }
          }
        },
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/product-variant/variant?page=1&limit=10" } },
        {
          "name": "Update (PATCH)",
          "request": {
            "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/product-variant/variant/1/",
            "body": { "mode": "raw", "raw": "{\n  \"price\": 95000\n}" }
          }
        },
        { "name": "Deactivate", "request": { "method": "DELETE", "url": "{{base_url}}/product-variant/variant/1/" } }
      ]
    },
    {
      "name": "5. Inventories",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/inventory/inventory?page=1&limit=10" } },
        {
          "name": "Update reorder_level only (PATCH)",
          "request": {
            "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/inventory/inventory/1/",
            "body": { "mode": "raw", "raw": "{\n  \"reorder_level\": 10\n}" }
          }
        }
      ]
    },
    {
      "name": "6. Stock Movements (immutable ledger)",
      "item": [
        {
          "name": "Create IN (ຮັບເຄື່ອງເຂົ້າສາງ)",
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/stock-movement/create",
            "body": { "mode": "raw", "raw": "{\n  \"product_variant_id\": 1,\n  \"movement_type\": \"IN\",\n  \"qty_change\": 50,\n  \"ref_type\": \"purchase\",\n  \"note\": \"ຮັບເຄື່ອງເຂົ້າສາງ\"\n}" }
          }
        },
        {
          "name": "Create OUT (ຂາຍອອກ)",
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/stock-movement/create",
            "body": { "mode": "raw", "raw": "{\n  \"product_variant_id\": 1,\n  \"movement_type\": \"OUT\",\n  \"qty_change\": -5,\n  \"ref_type\": \"order\",\n  \"note\": \"ຂາຍອອກ\"\n}" }
          }
        },
        { "name": "List by variant", "request": { "method": "GET", "url": "{{base_url}}/stock-movement/movement?product_variant_id=1&page=1&limit=20" } }
      ]
    },
    {
      "name": "7. Stock Reservations",
      "item": [
        {
          "name": "Create (ຈອງ stock)",
          "request": {
            "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/stock-reservation/create",
            "body": { "mode": "raw", "raw": "{\n  \"product_variant_id\": 1,\n  \"reserved_qty\": 2,\n  \"expires_at\": \"2026-12-31T00:00:00Z\"\n}" }
          }
        },
        { "name": "List by variant", "request": { "method": "GET", "url": "{{base_url}}/stock-reservation/reservation?product_variant_id=1" } },
        {
          "name": "Status -> COMPLETED (ຢືນຢັນຂາຍ)",
          "request": {
            "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/stock-reservation/reservation/1/status",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"COMPLETED\"\n}" }
          }
        },
        {
          "name": "Status -> EXPIRED (ຍົກເລີກການຈອງ)",
          "request": {
            "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/stock-reservation/reservation/1/status",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"EXPIRED\"\n}" }
          }
        }
      ]
    }
  ]
}
