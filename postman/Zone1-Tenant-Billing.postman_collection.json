{
  "info": {
    "name": "go-echo-template — Zone 1: Tenant/Billing",
    "description": "CRUD ຄົບ 5 feature ຂອງ Zone 1: subscription_plans, shops, shop_subscriptions, shop_bank_accounts, shop_settings. ຕັ້ງຄ່າ variable {{base_url}} ແລະ {{token}} ກ່ອນຍິງ.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "plan_id", "value": "" },
    { "key": "shop_id", "value": "" },
    { "key": "subscription_id", "value": "" },
    { "key": "bank_account_id", "value": "" }
  ],
  "item": [
    {
      "name": "0. Auth",
      "item": [
        {
          "name": "Login (ຕ້ອງແກ້ users feature ກ່ອນຈຶ່ງໃຊ້ໄດ້)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_name\": \"admin\",\n  \"password\": \"password123\"\n}"
            },
            "description": "ໝາຍເຫດ: db-schema/db-query ຂອງ users ຍັງ query ຫາຕາຕະລາງ \"User\" (ບໍ່ກົງກັບ DB ຈິງທີ່ຊື່ users) — ຕ້ອງແກ້ກ່ອນ login ຈຶ່ງຈະໃຊ້ໄດ້. ໃນລະຫວ່າງນີ້ໃຫ້ໃສ່ JWT ທົດສອບເອງໃນ variable token."
          }
        }
      ]
    },
    {
      "name": "1. Subscription Plans",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/subscription-plan/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan_name\": \"Starter\",\n  \"price_monthly\": 99.99,\n  \"max_users\": 3,\n  \"max_products\": 100,\n  \"features\": \"{\\\"live_selling\\\":true}\"\n}"
            }
          }
        },
        {
          "name": "List (pagination)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/subscription-plan/plan?page=1&limit=10"
          }
        },
        {
          "name": "Get by id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/subscription-plan/plan?id={{plan_id}}"
          }
        },
        {
          "name": "Update (PUT — ທັບທັງໝົດ)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/subscription-plan/plan/{{plan_id}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan_name\": \"Starter-Plus\",\n  \"price_monthly\": 149.99,\n  \"max_users\": 5,\n  \"max_products\": 200\n}"
            }
          }
        },
        {
          "name": "Update (PATCH — ບາງ field)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/subscription-plan/plan/{{plan_id}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"max_users\": 5\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Shops",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/shop/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shop_name\": \"Vientiane Fashion\",\n  \"phone\": \"02099999999\",\n  \"timezone\": \"Asia/Vientiane\"\n}"
            }
          }
        },
        {
          "name": "List (pagination)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/shop/shop?page=1&limit=10"
          }
        },
        {
          "name": "Get by id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/shop/shop?id={{shop_id}}"
          }
        },
        {
          "name": "Update (PUT)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/shop/shop/{{shop_id}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shop_name\": \"Vientiane Fashion Co.\",\n  \"phone\": \"02088888888\",\n  \"timezone\": \"Asia/Vientiane\"\n}"
            }
          }
        },
        {
          "name": "Update (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/shop/shop/{{shop_id}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"02077777777\"\n}"
            }
          }
        },
        {
          "name": "Change status (ACTIVE/SUSPENDED/TRIAL) — ໃຊ້ແທນລົບ",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/shop/shop/{{shop_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACTIVE\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "3. Shop Subscriptions",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/shop-subscription/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shop_id\": {{shop_id}},\n  \"plan_id\": {{plan_id}},\n  \"start_date\": \"2026-07-10\"\n}"
            }
          }
        },
        {
          "name": "List (pagination)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/shop-subscription/subscription?page=1&limit=10"
          }
        },
        {
          "name": "Get by id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/shop-subscription/subscription?id={{subscription_id}}"
          }
        },
        {
          "name": "Update (PATCH — plan_id / end_date)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/shop-subscription/subscription/{{subscription_id}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"end_date\": \"2026-08-10\"\n}"
            }
          }
        },
        {
          "name": "Change status (ACTIVE/EXPIRED/CANCELLED) — ໃຊ້ແທນລົບ",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/shop-subscription/subscription/{{subscription_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CANCELLED\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "4. Shop Bank Accounts",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/shop-bank-account/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shop_id\": {{shop_id}},\n  \"bank_name\": \"BCEL\",\n  \"account_number\": \"010-11-00-00000-1\",\n  \"account_name\": \"Vientiane Fashion Co\"\n}"
            }
          }
        },
        {
          "name": "List (pagination)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/shop-bank-account/bank-account?page=1&limit=10"
          }
        },
        {
          "name": "Get by id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/shop-bank-account/bank-account?id={{bank_account_id}}"
          }
        },
        {
          "name": "Update (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/shop-bank-account/bank-account/{{bank_account_id}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"promptpay_id\": \"020xxxxxxx\"\n}"
            }
          }
        },
        {
          "name": "Deactivate (DELETE — set is_active=false)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/shop-bank-account/bank-account/{{bank_account_id}}/"
          }
        }
      ]
    },
    {
      "name": "5. Shop Settings",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/shop-setting/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shop_id\": {{shop_id}},\n  \"currency\": \"LAK\",\n  \"vat_rate\": 7,\n  \"auto_reply_msg\": \"ຂອບໃຈທີ່ທັກມາ ຮ້ານຈະຕອບກັບໄວໆນີ້\"\n}"
            }
          }
        },
        {
          "name": "Get by shop_id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/shop-setting/setting/{{shop_id}}/"
          }
        },
        {
          "name": "Update (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/shop-setting/setting/{{shop_id}}/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vat_rate\": 10\n}"
            }
          }
        }
      ]
    }
  ]
}
