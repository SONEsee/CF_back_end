{
  "info": {
    "name": "go-echo-template — Zone 2: Auth/RBAC",
    "description": "modules, main_menus, sub_menus, roles, permissions, users, auth/login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "0. Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"user_name\": \"admin\",\n  \"password\": \"Admin@123\"\n}" }
          }
        },
        {
          "name": "Me (current user)",
          "request": { "method": "GET", "url": "{{base_url}}/users/me" }
        }
      ]
    },
    {
      "name": "1. Users",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/users/create",
            "body": { "mode": "raw", "raw": "{\n  \"role_id\": 1,\n  \"username\": \"staff01\",\n  \"password\": \"password123\",\n  \"full_name\": \"ພະນັກງານ\",\n  \"email\": \"staff01@example.com\"\n}" }
          }
        },
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/users/getData?page=1&limit=10" } },
        {
          "name": "Update (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/users/user-update/1",
            "body": { "mode": "raw", "raw": "{\n  \"phone\": \"02011112222\"\n}" }
          }
        },
        { "name": "Deactivate", "request": { "method": "DELETE", "url": "{{base_url}}/users/deleted/1" } }
      ]
    },
    {
      "name": "2. Modules",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/module/create",
            "body": { "mode": "raw", "raw": "{\n  \"module_name\": \"ຈັດການສິນຄ້າ\",\n  \"display_order\": 1\n}" }
          }
        },
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/module/module?page=1&limit=10" } }
      ]
    },
    {
      "name": "3. Main Menus",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/main/create",
            "body": { "mode": "raw", "raw": "{\n  \"module_id\": 1,\n  \"menu_name\": \"ລາຍການສິນຄ້າ\",\n  \"icon_class\": \"fa-box\"\n}" }
          }
        },
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/main/main-menu?page=1&limit=10" } },
        {
          "name": "Update (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/main/main-menu/1/",
            "body": { "mode": "raw", "raw": "{\n  \"icon_class\": \"fa-boxes\"\n}" }
          }
        },
        { "name": "Delete", "request": { "method": "DELETE", "url": "{{base_url}}/main/main-menu/1/" } }
      ]
    },
    {
      "name": "4. Sub Menus",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/sub/create",
            "body": { "mode": "raw", "raw": "{\n  \"main_menu_id\": 1,\n  \"submenu_name\": \"ລາຍການທັງໝົດ\",\n  \"route_path\": \"/products/list\"\n}" }
          }
        },
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/sub/sub-menu?page=1&limit=10" } },
        { "name": "Delete", "request": { "method": "DELETE", "url": "{{base_url}}/sub/sub-menu/1/" } }
      ]
    },
    {
      "name": "5. Roles",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/role/create",
            "body": { "mode": "raw", "raw": "{\n  \"role_name\": \"Staff\",\n  \"description\": \"ພະນັກງານທົ່ວໄປ\"\n}" }
          }
        },
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/role/role?page=1&limit=10" } },
        { "name": "Delete", "request": { "method": "DELETE", "url": "{{base_url}}/role/role/1/" } }
      ]
    },
    {
      "name": "6. Permissions",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/permission/create",
            "body": { "mode": "raw", "raw": "{\n  \"role_id\": 1,\n  \"submenu_id\": 1,\n  \"can_view\": true,\n  \"can_create\": true,\n  \"can_update\": true,\n  \"can_delete\": false\n}" }
          }
        },
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/permission/permission?page=1&limit=10" } },
        {
          "name": "Update (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/permission/permission/1/",
            "body": { "mode": "raw", "raw": "{\n  \"can_delete\": true\n}" }
          }
        },
        { "name": "Delete", "request": { "method": "DELETE", "url": "{{base_url}}/permission/permission/1/" } }
      ]
    }
  ]
}
